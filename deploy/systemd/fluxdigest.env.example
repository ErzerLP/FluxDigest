# FluxDigest 共享运行配置示例
# 首次部署时，可在服务器 shell 中先 export APP_* 环境变量，再运行 deploy-systemd.sh 自动生成正式 env 文件。

GIN_MODE=release
http_proxy=http://127.0.0.1:7890
https_proxy=http://127.0.0.1:7890
HTTP_PROXY=http://127.0.0.1:7890
HTTPS_PROXY=http://127.0.0.1:7890
APP_HTTP_PORT=18088
APP_DATABASE_DSN=postgres://rss:rss@127.0.0.1:5432/rss?sslmode=disable
APP_REDIS_ADDR=127.0.0.1:6379
APP_JOB_API_KEY=change-me
APP_JOB_QUEUE=default
APP_WORKER_CONCURRENCY=6

APP_MINIFLUX_BASE_URL=http://127.0.0.1:8080
APP_MINIFLUX_AUTH_TOKEN=change-me

APP_LLM_BASE_URL=https://api.openai.com/v1
APP_LLM_API_KEY=change-me
APP_LLM_MODEL=MiniMax-M2.7
APP_LLM_FALLBACK_MODELS=mimo-v2-pro
APP_LLM_TIMEOUT_MS=45000

# 建议显式设置 channel=halo，避免被输出目录配置误导到 markdown_export。
APP_PUBLISH_CHANNEL=halo
APP_PUBLISH_HALO_BASE_URL=http://127.0.0.1:8090
APP_PUBLISH_HALO_TOKEN=change-me
# 若使用 markdown 发布器，请改成 markdown 或 markdown_export，并设置 APP_PUBLISH_OUTPUT_DIR。
APP_PUBLISH_OUTPUT_DIR=/var/lib/fluxdigest/output
